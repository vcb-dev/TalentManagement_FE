{
  "name": "vcb-hrm",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "tunnel": "node scripts/ngrok-tunnel.mjs",
    "build": "vite build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "preview": "vite preview",
    "lint": "echo ESLint disabled",
    "format": "prettier --write .",
    "test": "vitest",
    "codegen": "openapi-typescript \"$VITE_API_URL/openapi.json\" -o src/types/api.generated.ts",
    "codegen:local": "openapi-typescript ./openapi.json -o src/types/api.generated.ts",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "postinstall": "openapi-typescript ./openapi.json -o src/types/api.generated.ts"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ],
    "*.{json,css,md}": [
      "node ./node_modules/prettier/bin/prettier.cjs --write"
    ]
  },
  "dependencies": {
    "@hookform/resolvers": "5.2.2",
    "@radix-ui/react-dropdown-menu": "2.1.16",
    "@radix-ui/react-label": "2.1.8",
    "@radix-ui/react-slot": "1.2.4",
    "@tanstack/react-query": "5.95.2",
    "@tanstack/react-router": "1.168.10",
    "@xstate/react": "6.1.0",
    "axios": "1.7.0",
    "class-variance-authority": "0.7.1",
    "clsx": "2.1.1",
    "date-fns": "4.1.0",
    "lucide-react": "1.7.0",
    "react": "19.2.4",
    "react-day-picker": "^9.11.3",
    "react-dom": "19.2.4",
    "react-dropzone": "14.2.2",
    "react-hook-form": "7.72.0",
    "recharts": "2.15.0",
    "sonner": "2.0.7",
    "tailwind-merge": "2.5.5",
    "xstate": "5.30.0",
    "zod": "3.25.76",
    "zustand": "5.0.12"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@ngrok/ngrok": "^1.7.0",
    "@tailwindcss/vite": "4.2.2",
    "@tanstack/router-plugin": "1.167.12",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.0",
    "@types/node": "22.19.3",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "4.7.0",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "jsdom": "26.1.0",
    "lint-staged": "16.3.0",
    "openapi-typescript": "7.13.0",
    "prettier": "3.8.1",
    "typescript": "5.8.2",
    "typescript-eslint": "8.51.0",
    "vite": "6.4.1",
    "vitest": "2.1.9"
  }
}
