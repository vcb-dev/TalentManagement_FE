# Sao chép thành `.env` và chỉnh theo máy.
VITE_API_URL=http://127.0.0.1:3003
VITE_APP_NAME=VCB HRM
VITE_APP_ENV=development

# `true` = đăng nhập + HR dùng mock (không cần BE). `false` hoặc bỏ = kết nối TalentManagement_BE (OAuth, /auth/me, /users/.../permissions).
VITE_USE_MOCK_API=false

# CSKH Quality — UI native trong app (/cskh-quality), gọi BE /cskh/*
# Giọng chúc mừng modal: cấu hình ElevenLabs trên backend (TalentManagement_BE/docs/elevenlabs-tts.md).
